PROCEDURE SP_RE_CUSTOMER_ONBOARDING
(
P_CUSTOMER_FIRST_NAME IN VARCHAR2,
P_CUSTOMER_MIDDLE_NAME IN VARCHAR2,
P_CUSTOMER_LAST_NAME IN VARCHAR2,
P_CUSTOMER_GENDER IN CHAR,
P_CUSTOMER_DATE_OF_BIRTH IN DATE,
P_CUSTOMER_MOBILE_NUMBER IN VARCHAR2,
P_PARENT_CUSTOMER_ID IN NUMBER,
P_CUSTOMER_PERMANENT_ADDRESS IN VARCHAR2,
P_CUSTOMER_TEMPORARY_ADDRESS IN VARCHAR2,
P_CUSTOMER_IDENTITY_PROOF_NAME IN VARCHAR2,
P_CUSTOMER_IDENTITY_PROOF_NUMBER IN VARCHAR2,
P_CUSTOMER_ADDRESS_PROOF_NAME IN VARCHAR2,
P_CUSTOMER_ADDRESS_PROOF_NUMBER IN VARCHAR2,
P_COUNTRY_NAME IN VARCHAR2,
P_STATE_NAME IN VARCHAR2,
P_DISTRICT_NAME IN VARCHAR2,
P_MANDAL_NAME IN VARCHAR2,
P_VILLAGE_NAME IN VARCHAR2,
P_PINCODE IN VARCHAR2,
P_CODE OUT NUMBER,
P_MESSAGE OUT VARCHAR2,
P_CUSTOMER_ID OUT NUMBER
)
AS
V_CUSTOMER_STATUS_ID NUMBER;
V_CUSTOMER_ID NUMBER;
V_CUSTOMER_PARENT_ID NUMBER;
V_COUNTRY_ID NUMBER;
V_STATE_ID NUMBER;
V_DISTRICT_ID NUMBER;
V_MANDAL_ID NUMBER;
V_VILLAGE_ID NUMBER;
V_ADDRESS_PROOF_ID NUMBER;
V_ID_PROOF_ID NUMBER;

BEGIN

V_CUSTOMER_PARENT_ID:=FN_GET_CUSTOMER_PARENT_ID(P_PARENT_CUSTOMER_ID);
V_COUNTRY_ID:=FN_GET_RE_COUNTRY_INFO(P_COUNTRY_NAME);
V_STATE_ID:=FN_GET_RE_STATE_INFO(P_STATE_NAME);
V_DISTRICT_ID:=FN_GET_RE_DISTRICT_INFO(P_DISTRICT_NAME);
V_MANDAL_ID:=FN_GET_RE_MANDAL_INFO(P_MANDAL_NAME);
V_VILLAGE_ID:=FN_GET_RE_VILLAGE_INFO(P_VILLAGE_NAME);
V_ADDRESS_PROOF_ID:=FN_GET_RE_ADDRESS_PROOF_TYPE_DETAILS(P_CUSTOMER_ADDRESS_PROOF_NAME);
V_ID_PROOF_ID:=FN_GET_RE_IDENTITY_PROF_TYPE_DETAILS(P_CUSTOMER_IDENTITY_PROOF_NAME);

IF P_CUSTOMER_MOBILE_NUMBER IS NULL THEN
   P_CODE:=104;
   P_MESSAGE:='Sorry,Your Mobile Number Is Null';
   P_CUSTOMER_ID:=0;
   RETURN;
   
   ELSIF LENGTH(P_CUSTOMER_MOBILE_NUMBER)!= 10 THEN
   P_CODE:=105;
   P_MESSAGE:='Invalid mobile number,Mobile Number Should be 10 Digits';
   P_CUSTOMER_ID:=0;
   RETURN;
   
   ELSIF P_CUSTOMER_FIRST_NAME IS NULL THEN
   P_CODE:=106;
   P_MESSAGE:='First Name Should not be null';
   P_CUSTOMER_ID:=0;
   RETURN;
   
   ELSIF P_CUSTOMER_LAST_NAME IS NULL THEN
   P_CODE:=106;
   P_MESSAGE:='Last Name Should not be null,user Creation failed';
   P_CUSTOMER_ID:=0;
   RETURN;
   
   ELSIF V_ID_PROOF_ID= -1 THEN
   P_CODE:= 108;
   P_MESSAGE:= 'Entered identity proof not exists,user creation failed';
   RETURN;
   
   ELSIF V_ADDRESS_PROOF_ID= -1 THEN
   P_CODE:= 109;
   P_MESSAGE:= 'Entered address proof not exists,user creation failed';
   P_CUSTOMER_ID:=0; 
   RETURN;
   
   ELSIF V_COUNTRY_ID = -1 THEN
   P_CODE:=110;
   P_MESSAGE:='Entered country proof not exists,user creation failed';
   P_CUSTOMER_ID:=0;
   RETURN;

   ELSIF V_STATE_ID= -1 THEN
   P_CODE:= 111;
   P_MESSAGE:= 'Entered state proof not exists,user creation failed';
   P_CUSTOMER_ID:=0;
   RETURN;

   ELSIF V_DISTRICT_ID= -1 THEN
   P_CODE:= 112;
   P_MESSAGE:= 'Entered district proof not exists,user creation failed';
   P_CUSTOMER_ID:=0;
   RETURN;

   ELSIF V_MANDAL_ID= -1 THEN
   P_CODE:= 113;
   P_MESSAGE:= 'Entered mandal proof not exists,user creation failed';
   P_CUSTOMER_ID:=0;
   RETURN;

   ELSIF V_VILLAGE_ID= -1 THEN
   P_CODE:= 114;
   P_MESSAGE:= 'Entered village proof not exists,user creation failed';
   P_CUSTOMER_ID:=0;
   RETURN;
   
   ELSIF V_ID_PROOF_ID= -1 THEN
   P_CODE:= 108;
   P_MESSAGE:= 'Entered identity proof not exists,user creation failed';
   RETURN;
   
   ELSIF V_ADDRESS_PROOF_ID= -1 THEN
   P_CODE:= 109;
   P_MESSAGE:= 'Entered address proof not exists,user creation failed';
   RETURN;
   
   ELSIF V_COUNTRY_ID = -1 THEN
   P_CODE:=110;
   P_MESSAGE:='Entered country proof not exists,user creation failed';
   P_CUSTOMER_ID:=0;
   RETURN;

   ELSIF V_STATE_ID= -1 THEN
   P_CODE:= 111;
   P_MESSAGE:= 'Entered state proof not exists,user creation failed';
   P_CUSTOMER_ID:=0;
   RETURN;

   ELSIF V_DISTRICT_ID= -1 THEN
   P_CODE:= 112;
   P_MESSAGE:= 'Entered district proof not exists,user creation failed';
   P_CUSTOMER_ID:=0;
   RETURN;

   ELSIF V_MANDAL_ID= -1 THEN
   P_CODE:= 113;
   P_MESSAGE:= 'Entered mandal proof not exists,user creation failed';
   P_CUSTOMER_ID:=0;
   RETURN;

   ELSIF V_VILLAGE_ID= -1 THEN
   P_CODE:= 114;
   P_MESSAGE:= 'Entered village proof not exists,user creation failed';
   P_CUSTOMER_ID:=0;
   RETURN;
   
   ELSIF V_CUSTOMER_PARENT_ID = -1 THEN
   P_CODE:= 115;
   P_MESSAGE:= 'Entered parent not exists,user creation failed';
   P_CUSTOMER_ID:=0;
   RETURN;
   
END IF;

V_CUSTOMER_ID:=CUSTOMER_ID_SEQ.NEXTVAL;
   
INSERT INTO RE_TBL_CUSTOMER_AUTHENTICATION
      (
        RE_RTCA_CUS_ID,
        RE_RTCA_CUS_MOBILE_NUMBER,
        RE_RTCA_CUS_PASSWORD,
        RE_RTCA_CUS_NO_OF_ATTEMPTS,
        RE_RTCA_CUS_STATUS,
        RE_RTCA_CUS_CREATION_DATE,
        RE_RTCA_CUS_CREATED_BY,

CREATE OR REPLACE PACKAGE BODY QUICKPAY_PACKAGE AS

FUNCTION FN_GET_CUSTOMER_PARENT_ID
(
P_CUSTOMER_PARENT_ID  NUMBER
)
RETURN NUMBER
AS
V_CUSTOMER_PARENT_ID RE_TBL_CUSTOMER_AUTHENTICATION.RE_RTCA_CUS_PARENT_CUS_ID%TYPE;
BEGIN
IF P_CUSTOMER_PARENT_ID IS NULL THEN
RETURN NULL;
ELSE
SELECT RE_RTCA_CUS_ID INTO V_CUSTOMER_PARENT_ID FROM RE_TBL_CUSTOMER_AUTHENTICATION
WHERE RE_RTCA_CUS_ID = P_CUSTOMER_PARENT_ID;
RETURN V_CUSTOMER_PARENT_ID;
END IF;
EXCEPTION
WHEN OTHERS THEN
RETURN -1;
END FN_GET_CUSTOMER_PARENT_ID;

FUNCTION FN_GET_CUSTOMER_STATUS_ID
(
P_CUSTOMER_STATUS  VARCHAR2
)
RETURN NUMBER
AS
V_CUSTOMER_STATUS_ID RE_TBL_CUSTOMER_STATUS.RE_RTCS_STATUS_ID%TYPE;
BEGIN
SELECT RE_RTCS_STATUS_ID INTO V_CUSTOMER_STATUS_ID FROM RE_TBL_CUSTOMER_STATUS
WHERE RE_RTCS_STATUS = P_CUSTOMER_STATUS;
RETURN V_CUSTOMER_STATUS_ID;
EXCEPTION
WHEN OTHERS THEN
RETURN -1;
END FN_GET_CUSTOMER_STATUS_ID;

FUNCTION FN_GET_RE_ADDRESS_PROOF_TYPE_DETAILS
(
P_ADDRESS_PROOF_NAME  VARCHAR2
)
RETURN NUMBER
AS
V_APTD_TYPE_ID RE_ADDRESS_PROF_TYPE_DETAILS.RE_APTD_TYPE_ID%TYPE;
BEGIN
SELECT RE_APTD_TYPE_ID INTO V_APTD_TYPE_ID FROM RE_ADDRESS_PROF_TYPE_DETAILS
WHERE RE_APTD_TYPE_NAME = P_ADDRESS_PROOF_NAME;
RETURN V_APTD_TYPE_ID;
EXCEPTION
WHEN OTHERS THEN
RETURN -1;
END FN_GET_RE_ADDRESS_PROOF_TYPE_DETAILS;


